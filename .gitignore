# Personal data — never commit these
jobs.xlsx
jobs-pending-merge-*.xlsx
logs/
versions/
digest-*.md
outreach/*.json

# Per-user config — buyer creates from .example.yaml
config/user.yaml

# SMTP credentials (Gmail app password) — buyer creates from .example.json
config/smtp.json

# Per-user resume content — buyer creates from .example.tex
master/*.tex
!master/*.example.tex

# Resume materials each user adds in their own clone
profile.md
skills.md
experiences/
research/

# A user's filled-in LaunchAgent plist (the .template stays committed)
launchd/daily-sourcing.plist

# Python
__pycache__/
*.pyc
*.pyo

# AppleScript intermediate files written by the spawner
*.applescript

# Backup directories
*-backup-*/

# macOS
.DS_Store

# Editor cruft
*.swp
.idea/
.vscode/
